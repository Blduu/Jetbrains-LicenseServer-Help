# --- Certificates & keys ---
# Ignore generated / secret material; allow checked-in bootstrap roots only.
**/*.pem
**/*.cer
**/*.p12
**/*.jks
**/*.keystore
**/*.truststore
**/*.key
!src/main/resources/external/certificate/code-root.key
!src/main/resources/external/certificate/server-root.key

# --- Logs & diagnostics ---
logs/
*.log
hs_err_pid*
replay_pid*
*.hprof

# --- Spring: local overrides ---
**/application-local.yml
**/application-dev.yml
**/application-prod.yml
**/application-*.local.yml
**/*.properties.local

# --- Environment ---
.env
.env.local
.env.*.local

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

